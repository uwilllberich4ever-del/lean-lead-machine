# Configuration API MCP data.gouv.fr
# ====================================

# URL de base de l'API MCP
# Note: L'URL exacte doit être vérifiée dans la documentation MCP
MCP_API_URL=https://api.data.gouv.fr

# Clé API MCP (obligatoire pour la production)
# Obtenez votre clé sur: https://www.data.gouv.fr/fr/datasets/api-sirene/
MCP_API_KEY=votre_cle_api_mcp_data_gouv_fr

# Cache Redis (Upstash recommandé pour Vercel)
UPSTASH_REDIS_URL=redis://votre-url.upstash.io:6379
UPSTASH_REDIS_TOKEN=votre_token_upstash

# Configuration du cache (secondes)
MCP_CACHE_TTL=86400  # 24 heures (conformité RGPD)
MCP_CACHE_ENABLED=true

# Limites et retry
MCP_MAX_RETRIES=3
MCP_RATE_LIMIT_PER_MINUTE=60
MCP_TIMEOUT_MS=5000

# Fallback configuration
MCP_FALLBACK_ENABLED=true
MCP_FALLBACK_TO_MOCK=true  # Utiliser mock data si API indisponible

# Monitoring
MCP_METRICS_ENABLED=true
MCP_LOG_LEVEL=info  # debug, info, warn, error

# Sécurité
MCP_VALIDATE_INPUTS=true
MCP_SANITIZE_OUTPUTS=true

# Performance
MCP_PARALLEL_REQUESTS=true
MCP_PREFETCH_ENABLED=true
MCP_COMPRESSION_ENABLED=true

# ====================================
# Notes importantes:
# ====================================
# 1. RGPD Compliance:
#    - Cache limité à 24h maximum
#    - Pas de stockage permanent des données personnelles
#    - Logs anonymisés (pas de SIREN dans les logs)
#
# 2. Rate Limiting:
#    - L'API MCP a des limites de taux strictes
#    - Utiliser le cache agressivement
#    - Implémenter un circuit breaker
#
# 3. Fallback Strategy:
#    - Niveau 1: Cache Redis
#    - Niveau 2: Mock data (développement uniquement)
#    - Niveau 3: Message d'erreur utilisateur
#
# 4. Monitoring:
#    - Surveiller la latence (< 1s P95)
#    - Surveiller le taux d'erreur (< 5%)
#    - Surveiller le cache hit rate (> 80%)