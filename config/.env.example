# Configuration Environnement - Lean Lead Machine MVP V1

# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ============================================
# API MCP (data.gouv.fr)
# ============================================
NEXT_PUBLIC_MCP_API_URL=https://mcp.data.gouv.fr/mcp
MCP_API_KEY=votre_cle_api_mcp_ici
MCP_API_TIMEOUT=5000
MCP_CACHE_TTL=86400 # 24h en secondes

# ============================================
# CACHE REDIS (Supabase Redis ou Vercel KV)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=86400 # 24h en secondes

# Pour Vercel KV:
# KV_URL=your-kv-url
# KV_REST_API_URL=your-kv-rest-api-url
# KV_REST_API_TOKEN=your-kv-rest-api-token
# KV_REST_API_READ_ONLY_TOKEN=your-kv-read-only-token

# ============================================
# SUPABASE (Cache et Auth optionnel)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================
# STRIPE (Payments - V2)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# SÉCURITÉ
# ============================================
API_RATE_LIMIT_WINDOW_MS=60000 # 1 minute
API_RATE_LIMIT_MAX_REQUESTS=100
EXPORT_RATE_LIMIT_MAX_REQUESTS=10
JWT_SECRET=your-jwt-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# ============================================
# MONITORING & LOGS
# ============================================
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key
VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# ============================================
# LIMITES APPLICATION
# ============================================
MAX_EXPORT_ROWS=500
MAX_SEARCH_RESULTS=1000
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
SEARCH_TIMEOUT_MS=5000
EXPORT_TIMEOUT_MS=10000

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_FEATURE_EXPORT=true
NEXT_PUBLIC_FEATURE_SUGGESTIONS=true
NEXT_PUBLIC_FEATURE_CACHE=true
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# ============================================
# URLs EXTERNES
# ============================================
NEXT_PUBLIC_DOCS_URL=/docs
NEXT_PUBLIC_API_DOCS_URL=/api-docs
NEXT_PUBLIC_GITHUB_URL=https://github.com/uwilllberich4ever-del/lean-lead-machine
NEXT_PUBLIC_DATA_GOUV_URL=https://www.data.gouv.fr

# ============================================
# MESSAGES D'ERREUR (Personnalisation)
# ============================================
NEXT_PUBLIC_ERROR_MCP_UNAVAILABLE=Le service de données est temporairement indisponible. Veuillez réessayer dans quelques instants.
NEXT_PUBLIC_ERROR_NO_RESULTS=Aucune entreprise ne correspond à vos critères de recherche.
NEXT_PUBLIC_ERROR_EXPORT_LIMIT=L'export dépasse la limite de 500 lignes. Veuillez affiner vos critères.
NEXT_PUBLIC_ERROR_INVALID_POSTAL=Le code postal saisi n'est pas valide. Veuillez saisir un code postal français à 5 chiffres.

# ============================================
# CONFIGURATION CSV
# ============================================
CSV_SEPARATOR=;
CSV_ENCODING=utf8
CSV_INCLUDE_BOM=true
CSV_MAX_FILE_SIZE_MB=10

# ============================================
# MAINTENANCE
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Le service est en maintenance. Veuillez réessayer ultérieurement.
