# ===========================================
# LEAN LEAD MACHINE - Configuration MVP V1
# ===========================================
# Template pour développement et production
# ===========================================

# Google Maps & Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=votre_cle_google_maps_frontend  # Maps JavaScript API (frontend)
GOOGLE_PLACES_API_KEY=votre_cle_google_places_backend           # Places API (backend - sécurisé)

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_supabase
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_supabase       # Optionnel: pour opérations admin

# MCP Server (data.gouv.fr via Supabase)
NEXT_PUBLIC_MCP_SERVER_URL=https://mcp.supabase.com/mcp?project_ref=votre_ref_projet
# MCP_API_KEY=non_requis_pour_mcp_supabase

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000                      # Dev: localhost, Prod: votre-domaine.vercel.app
NEXT_PUBLIC_ENABLE_STRIPE_PAYMENTS=false                       # MVP V1: false, V2: true
NEXT_PUBLIC_CSV_EXPORT_LIMIT=500                               # Limite MVP

# Feature Flags (MVP V1)
NEXT_PUBLIC_ENABLE_LINKEDIN_SCRAPING=false                     # MVP V1: false (reporté à V2)
NEXT_PUBLIC_ENABLE_GOOGLE_MAPS=true
NEXT_PUBLIC_ENABLE_CSV_EXPORT=true

# Security & Rate Limiting
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW_MS=900000                       # 15 minutes

# ===========================================
# NOTES IMPORTANTES :
# ===========================================
# 1. Variables avec NEXT_PUBLIC_ : accessibles côté client (browser)
# 2. Variables sans NEXT_PUBLIC_ : backend-only (sécurisées)
# 3. Pour Vercel : ajouter toutes ces variables dans Environment Variables
# 4. Pour Stripe (V2) : ajouter les clés Stripe appropriées
# ===========================================